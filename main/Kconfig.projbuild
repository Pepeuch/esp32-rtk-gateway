choice APP_BOARD_TYPE
    prompt "Target board"
    default BOARD_WAVESHARE_ESP32S3_ETH

config BOARD_WAVESHARE_ESP32S3_ETH
    bool "Waveshare ESP32-S3-ETH"

config BOARD_MAMMOTION_ESP32S3
    bool "Mammotion ESP32-S3"

config BOARD_GENERIC_ESP32C3
    bool "Generic ESP32-C3"

config BOARD_GENERIC_ESP32C6
    bool "Generic ESP32-C6"

config BOARD_GENERIC_ESP32
    bool "Generic ESP32"

config BOARD_GENERIC_ESP32_ETH
    bool "Generic ESP32 ETH"

endchoice

config ETHERNET_DHCP_TIMEOUT_MS
    int "Ethernet DHCP timeout (ms)"
    default 12000
    range 1000 60000
    help
        How long to wait for an Ethernet IPv4 address after the PHY link is up
        before starting WiFi fallback. This is only a firmware policy timeout,
        not a guarantee about network behavior.

choice GNSS_RECEIVER_DEFAULT
    prompt "Default GNSS receiver family"
    default GNSS_RECEIVER_DEFAULT_AUTO

config GNSS_RECEIVER_DEFAULT_AUTO
    bool "Auto detect"

config GNSS_RECEIVER_DEFAULT_UBLOX
    bool "u-blox"

config GNSS_RECEIVER_DEFAULT_UNICORE
    bool "Unicore"

config GNSS_RECEIVER_DEFAULT_NMEA
    bool "Generic NMEA"

config GNSS_RECEIVER_DEFAULT_SEPTENTRIO
    bool "Septentrio"

endchoice

choice RTK_DEVICE_ROLE
    prompt "RTK device role"
    default RTK_DEVICE_ROLE_BASE

config RTK_DEVICE_ROLE_BASE
    bool "BASE"
    help
        Build the RTK base pipeline: GNSS UART input, RTCM filtering,
        LoRa fragmentation/transmit, and network or storage features if available.

config RTK_DEVICE_ROLE_ROVER
    bool "ROVER"
    help
        Build the RTK rover pipeline: LoRa receive/reassembly and GNSS UART output only.
        Ethernet, SD, web server, and NTRIP features stay disabled.

config RTK_DEVICE_ROLE_DUAL_DEBUG
    bool "DUAL_DEBUG"
    help
        Build both pipelines for ESP32-S3 debug and loop testing.
        Intended for development use rather than deployment.

endchoice
